# Stellar / Soroban
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_RPC_URLS=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CERTIFICATE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# API Server
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=1h
API_KEY_SALT=change-me-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_VERIFY_MAX=100

# Per-user tier limits (requests per minute / burst per 10s)
RATE_LIMIT_FREE_RPM=30
RATE_LIMIT_FREE_BURST=10
RATE_LIMIT_PRO_RPM=120
RATE_LIMIT_PRO_BURST=30
RATE_LIMIT_ENT_RPM=600
RATE_LIMIT_ENT_BURST=100
RATE_LIMIT_INTERNAL_RPM=6000
RATE_LIMIT_INTERNAL_BURST=500

# CDN
CDN_ORIGIN=https://dXXXXXXXXXXXX.cloudfront.net
CDN_MAX_AGE=31536000
CDN_S_MAX_AGE=86400
CDN_SWR=3600
CDN_INVALIDATION_SECRET=change-me-in-production
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXX

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.strellerminds.com

# Query optimization / Soroban backend pool
# Optional comma-separated RPC URLs. If omitted, STELLAR_RPC_URL is reused.
QUERY_POOL_SIZE=4
QUERY_CACHE_MAX_ENTRIES=1000
QUERY_CACHE_DEFAULT_TTL_MS=60000
QUERY_CACHE_ANALYTICS_TTL_MS=15000
QUERY_CACHE_STUDENT_CERTS_TTL_MS=30000
QUERY_CACHE_CERTIFICATE_TTL_MS=60000
QUERY_CACHE_REVOCATION_TTL_MS=300000
QUERY_SLOW_THRESHOLD_MS=100
QUERY_TARGET_AVG_MS=100
QUERY_TARGET_LOAD_REDUCTION_PERCENT=40

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_TTL_CERTIFICATE=3600
REDIS_TTL_PROFILE=1800
REDIS_TTL_ACHIEVEMENT=3600
REDIS_TTL_STATISTICS=900
REDIS_TTL_COHORT=1800
REDIS_TTL_LEADERBOARD=300

# Database Connection Pool
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strellerminds
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_CONNECT_TIMEOUT=10000
DATABASE_POOL_MAX_USES=10000
DATABASE_POOL_LEAK_THRESHOLD=60000

# Export Configuration
EXPORT_MAX_RECORDS=100000
EXPORT_STREAMING_THRESHOLD=10000
EXPORT_DEFAULT_PAGE_SIZE=1000
# Slack Notifications
# Default incoming webhook URL (required to enable Slack notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_CHANNEL/YOUR_TOKEN
# Optional per-channel webhook overrides
SLACK_ALERTS_WEBHOOK_URL=
SLACK_CERTIFICATES_WEBHOOK_URL=
# Default channel (e.g. #notifications). Leave blank to use webhook default.
SLACK_DEFAULT_CHANNEL=#notifications
SLACK_ALERTS_CHANNEL=#alerts
SLACK_CERTIFICATES_CHANNEL=#certificates
# Bot display name
SLACK_USERNAME=StrellerMinds
# Signing secret for webhook management API (optional, for request verification)
SLACK_SIGNING_SECRET=change-me-in-production
