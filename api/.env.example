# Stellar / Soroban
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CERTIFICATE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# API Server
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=1h
API_KEY_SALT=change-me-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_VERIFY_MAX=100

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.strellerminds.com

# ── Google Analytics 4 (Measurement Protocol) ─────────────────────────────────
# Get Measurement ID: GA4 → Admin → Data Streams → select stream → Measurement ID
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Get API Secret: GA4 → Admin → Data Streams → select stream → Measurement Protocol API secrets
GA4_API_SECRET=your-mp-api-secret-here
# Set to "false" to disable GA4 tracking entirely (e.g. in CI/test environments)
GA4_ENABLED=true
# Set to "true" to log GA4 debug/validation responses during local development
GA4_DEBUG=false
